<% layout("./layouts/boilerplate.ejs")-%><body>
    <h3>Listing Details:</h3>
    <ul>
        <li><%=list.title%></li>
         <li><%=list.description%></li>
        <!--used local e string function to add comma in price  -->
        <li>$<%=list.price.toLocaleString("en-IN")%></li>
        <li><%=list.location%></li>
        <li><%=list.country%></li>   
    </ul>
    <br>
    <a href="/listings/<%=list._id%>/edit">Edit this Listening</a>
    <br><br>
    <form action="/listings/<%=list._id%>/delete?_method=DELETE" method="POST">
        <button>Delete this Listing</button>
    </form>
</body>
