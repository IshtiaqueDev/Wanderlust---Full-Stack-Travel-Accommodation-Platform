<% layout("./layouts/boilerplate.ejs")-%><body>
    <div class="row mt-3">
        <div class="col-8 offset-3 ">
    <h3><%=list.title%></h3> 
    </div>
    <div class="card col-6 offset-3 show-card" style="border: none;">
  <img src="<%=list.image.url%>" class="card-img-top show-img" alt="listing_Image">
  <div class="card-body">
  <p class="card-text">
    <!-- <b><%=list.title%></b><br> -->
    <%=list.description%> <br>
    $<%=list.price.toLocaleString("en-IN")%> <br>
    <%=list.location%> <br>
    <%=list.country%>
   </p>
  </div>
    </div>
    </div>
    <br>
     <div class="btns">
    <br>
    <a href="/listings/<%=list._id%>/edit" class="btn btn-dark col-1 offset-3">Edit</a>
    <form action="/listings/<%=list._id%>/delete?_method=DELETE" method="POST">
        <button class="btn btn-dark offset-5">Delete</button>
    </form>
    </div>
    <br><br> 
    <hr>    
    <div class="col-8 offset-3 mb-3">
        <h4>Leave a Review</h4>
        <form action="/listings/<%=list._id%>/reviews" method="POST" class="mb-3">
            <div class="mb-3 mt-3">
                <label for="rating" class="form-label">Rating:</label>
                <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range">
            </div>
            <div>
                <label for="comment" class="form-label">Comments</label><br>    
                <textarea resize="none" class="form-control" name="review[comment]" id="comment" cols="30" rows="5"></textarea>
            </div>
            <button class="btn btn-dark mt-3">Submit</button>
        </form>
    </div>
