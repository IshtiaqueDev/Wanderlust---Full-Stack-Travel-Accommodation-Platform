<% layout("./layouts/boilerplate.ejs")-%><body>
<%if(allListings.length>0){%>
  <h4 class="mt-2">Searched Results for <%=allListings[0].country%></h4>
<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 mt-3">
  <% for(let list of allListings){ %>
    <div class="col mb-4">  
    <a href="/listings/<%=list.id%>" class="listing_link">
      <div class="card h-100 listing-card">
        <img src="<%=list.image.url%>" class="card-img-top" style="height: 20rem;" alt="listing_image">
         <div class="card-img-overlay"></div>
        <div class="card-body">
          <p class="card-text">
           <b> <%=list.title%></b>
            <br>
            $<%=list.price.toLocaleString("en-IN")%> /night
            <i class="tax-info">&nbsp; &nbsp; +18% GST</i>
          </p>
        </div>
      </div></a>
    </div>

  <% } %>
</div>
<%}else{%>
  <h3 class="text-center mt-4">
    No listings found for your search. Try different keywords.
</h3>
<%}%>